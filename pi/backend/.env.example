# Cloud API
CLOUD_API_URL=https://your-cloud-api.example.com
STORE_API_KEY=your-per-store-api-key-here
STORE_ID=your-store-uuid-here

# CUPS printer names (run `lpstat -p` on the Pi to find these)
PHOTO_PRINTER_NAME=Canon_PIXMA_TS8320
DOCUMENT_PRINTER_NAME=HP_LaserJet_Pro

# Local storage — temp dir is wiped after each job (print-and-delete)
TEMP_DIR=/tmp/printjobs

# Heartbeat interval in seconds
HEARTBEAT_INTERVAL=60
